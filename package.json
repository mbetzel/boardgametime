{
  "name": "boardgametime-root",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/games/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:services": "docker-compose up -d",
    "dev:db": "pnpm --filter @boardgametime/db exec prisma db push && pnpm --filter @boardgametime/db seed",
    "dev:all": "pnpm dev:services && pnpm dev:db && pnpm dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
